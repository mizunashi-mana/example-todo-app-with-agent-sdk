{
  "name": "@example-todo-app/todo-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json && node dist/index.js",
    "dev:watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run --passWithNoTests",
    "test:update": "vitest run --update",
    "lint:eslint": "eslint --cache --fix src",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0 OR MPL-2.0",
  "dependencies": {},
  "devDependencies": {
    "@example-todo-app/eslint-config": "*",
    "@types/node": "^25.2.3",
    "eslint": "^9.39.2",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  }
}
