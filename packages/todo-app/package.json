{
  "name": "@example-todo-app/todo-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#models": {
      "types": "./src/models/index.ts",
      "default": "./dist/models/index.js"
    },
    "#storage": {
      "types": "./src/storage/index.ts",
      "default": "./dist/storage/index.js"
    },
    "#tools": {
      "types": "./src/tools/index.ts",
      "default": "./dist/tools/index.js"
    },
    "#agent": {
      "types": "./src/agent/index.ts",
      "default": "./dist/agent/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "tsc -p tsconfig.build.json && node dist/main.js",
    "dev": "tsc -p tsconfig.build.json && node dist/main.js",
    "dev:watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "lint:eslint": "eslint --cache --fix src",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0 OR MPL-2.0",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "ai": "^6.0.105",
    "ai-sdk-ollama": "^3.8.0",
    "hono": "^4.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@example-todo-app/eslint-config": "*",
    "@types/node": "^25.2.3",
    "eslint": "^9.39.2",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  }
}
